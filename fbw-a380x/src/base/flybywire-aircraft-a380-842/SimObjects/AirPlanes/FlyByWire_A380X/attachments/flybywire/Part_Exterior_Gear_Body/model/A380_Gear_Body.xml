<ModelInfo>
	<LODS>
		<LOD minSize="0" ModelFile="../../Part_Exterior_Gear_Body/model/A380_GEAR_BODY.gltf"/>
	</LODS>
	<Behaviors>
		<Include ModelBehaviorFile="Asobo\Common.xml"/>
		<Include ModelBehaviorFile="Asobo\Exterior.xml"/>
		<Include ModelBehaviorFile="Asobo\Generic\Interactions.xml"/>
		<Include ModelBehaviorFile="Asobo\Generic\FX.xml"/>
		<Component ID="GEARS">

			<!-- LH Body Gear -->
			<UseTemplate Name="ASOBO_GT_Anim">
				<ANIM_NAME>l_b_gear</ANIM_NAME>
				<ANIM_CODE>(L:A32NX_GEAR_LEFT_POSITION) 0.5 * (A:CONTACT POINT COMPRESSION:1, Percent) 0.5 * +</ANIM_CODE>
			</UseTemplate>

			<!-- RH Body Gear -->
			<UseTemplate Name="ASOBO_GT_Anim">
				<ANIM_NAME>r_b_gear</ANIM_NAME>
				<ANIM_CODE>(L:A32NX_GEAR_RIGHT_POSITION) 0.5 * (A:CONTACT POINT COMPRESSION:2, Percent) 0.5 * +</ANIM_CODE>
			</UseTemplate>

			<!-- rear left Steering -->
			<UseTemplate Name="ASOBO_GT_Anim_Code">
				<NODE_ID>left_bws</NODE_ID>
				<ANIM_NAME>left_bws</ANIM_NAME>
				<ANIM_CODE>(L:A32NX_LEFT_BODY_WHEEL_STEERING_POSITION)</ANIM_CODE>
				<ANIM_LENGTH>1</ANIM_LENGTH>
			</UseTemplate>

			<!-- rear right Steering -->
			<UseTemplate Name="ASOBO_GT_Anim_Code">
				<NODE_ID>right_bws</NODE_ID>
				<ANIM_NAME>right_bws</ANIM_NAME>
				<ANIM_CODE>(L:A32NX_RIGHT_BODY_WHEEL_STEERING_POSITION)</ANIM_CODE>
				<ANIM_LENGTH>1</ANIM_LENGTH>
			</UseTemplate>

			<!-- Wheel Rotation REAR LEFT LH-->
			<UseTemplate Name="ASOBO_GT_Anim_Code">
				<NODE_ID>ll_tire_key</NODE_ID>
				<ANIM_NAME>ll_tire_key</ANIM_NAME>
				<ANIM_CODE>(L:A32NX_LEFT_BODY_WHEEL_STEERING_LEFT_ANIM_ANGLE)</ANIM_CODE>
				<ANIM_LENGTH>360</ANIM_LENGTH>
			</UseTemplate>

			<!-- Wheel Rotation REAR LEFT RH-->
			<UseTemplate Name="ASOBO_GT_Anim_Code">
				<NODE_ID>lr_tire_key</NODE_ID>
				<ANIM_NAME>lr_tire_key</ANIM_NAME>
				<ANIM_CODE>(L:A32NX_LEFT_BODY_WHEEL_STEERING_RIGHT_ANIM_ANGLE)</ANIM_CODE>
				<ANIM_LENGTH>360</ANIM_LENGTH>
			</UseTemplate>

			<!-- Wheel Rotation REAR RIGHT LH-->
			<UseTemplate Name="ASOBO_GT_Anim_Code">
				<NODE_ID>rl_tire_key</NODE_ID>
				<ANIM_NAME>rl_tire_key</ANIM_NAME>
				<ANIM_CODE>(L:A32NX_RIGHT_BODY_WHEEL_STEERING_LEFT_ANIM_ANGLE)</ANIM_CODE>
				<ANIM_LENGTH>360</ANIM_LENGTH>
			</UseTemplate>

			<!-- Wheel Rotation REAR RIGHT RH-->
			<UseTemplate Name="ASOBO_GT_Anim_Code">
				<NODE_ID>rr_tire_key</NODE_ID>
				<ANIM_NAME>rr_tire_key</ANIM_NAME>
				<ANIM_CODE>(L:A32NX_RIGHT_BODY_WHEEL_STEERING_RIGHT_ANIM_ANGLE)</ANIM_CODE>
				<ANIM_LENGTH>360</ANIM_LENGTH>
			</UseTemplate>

			<!-- Body Gear Rotation-->
			<UseTemplate Name="ASOBO_GEAR_Back_Tire_Template">
				<ANIM_NAME>b_tire_key</ANIM_NAME>
				<NODE_ID_STILL>LANDINGGEAR_Back_Wheel1_Still_Right</NODE_ID_STILL>
				<NODE_ID_STILL_2>LANDINGGEAR_Back_Wheel2_Still_Right</NODE_ID_STILL_2>
				<NODE_ID_STILL_3>LANDINGGEAR_Back_Wheel1_Still_Left</NODE_ID_STILL_3>
				<NODE_ID_STILL_4>LANDINGGEAR_Back_Wheel2_Still_Left</NODE_ID_STILL_4>
				<NO_STILL_BLURRED_TRANSITION/>
			</UseTemplate>

		</Component>

		<Component ID="LANDING_GEAR_TILT">

            <!-- LH Body Tilt-->
            <UseTemplate Name="ASOBO_GT_Anim">
                <ANIM_NAME>l_b_gear_tilt</ANIM_NAME>
                <ANIM_CODE>(L:A32NX_GEAR_1_TILT_POSITION, Percent over 100) 100 *</ANIM_CODE>
            </UseTemplate>

            <!-- RH Body Tilt-->
            <UseTemplate Name="ASOBO_GT_Anim">
                <ANIM_NAME>r_b_gear_tilt</ANIM_NAME>
                <ANIM_CODE>(L:A32NX_GEAR_2_TILT_POSITION, Percent over 100) 100 *</ANIM_CODE>
            </UseTemplate>

        </Component>
	</Behaviors>
</ModelInfo>
